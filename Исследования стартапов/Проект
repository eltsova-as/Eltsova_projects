   "source": [
    "# Вычисляем квартили Q1 и Q3\n",
    "Q1 = base_company[\"funding_total\"].quantile(0.25)\n",
    "Q3 = base_company[\"funding_total\"].quantile(0.75)\n",
    "\n",
    "# Вычисляем межквартильный размах IQR\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "# Определяем верхний и нижний пороги для выбросов\n",
    "low_bound = Q1 - 1.5 * IQR\n",
    "up_bound = Q3 + 1.5 * IQR\n",
    "\n",
    "# Определим 95-й и 99-й процентиль\n",
    "percentile_95 = base_company[\"funding_total\"].quantile(0.95)\n",
    "percentile_99 = base_company[\"funding_total\"].quantile(0.99)\n",
