    "print(f\"99-й процентиль: {percentile_99}\")\n",
    "\n",
    "from scipy import stats\n",
    "\n",
    "# Вычисляем процентили для границ выбросов\n",
    "low_bound_percentile = stats.percentileofscore(base_company[\"funding_total\"], low_bound)\n",
    "up_bound_percentile = stats.percentileofscore(base_company[\"funding_total\"], up_bound)\n",
